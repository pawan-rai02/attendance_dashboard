# Environment Configuration for Attendance Dashboard
# Copy this file to .env and update values for your environment

# ===========================================
# Application Settings
# ===========================================
APP_NAME="College Attendance Analytics Dashboard"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/attendance_db

# Connection Pool Settings
POOL_SIZE=10
MAX_OVERFLOW=20

# SQL Debug (set to 'true' to log SQL queries)
SQL_ECHO=false

# ===========================================
# API Configuration
# ===========================================
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000,http://127.0.0.1:8501

# ===========================================
# Security (for production)
# ===========================================
# SECRET_KEY=your-secret-key-here
# API_KEY=your-api-key-here

# ===========================================
# ML Model Settings
# ===========================================
MODEL_PATH=ml/models
ENABLE_ML_PREDICTION=true

# ===========================================
# Seed Data (for development)
# ===========================================
SEED_DATA=true

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ===========================================
# Frontend (Streamlit)
# ===========================================
STREAMlit_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
